{
  "expo": {
    "name": "SPET",
    "slug": "spet-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "spet",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/spet-mobile",
      "fallbackToCacheTimeout": 5000
    },
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spetapp.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NFCReaderUsageDescription": "SPET uses NFC to scan guest wristbands for fast venue entry.",
        "com.apple.developer.nfc.readersession.iso7816.select-identifiers": [],
        "com.apple.developer.nfc.readersession.felica.systemcodes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.spetapp.mobile",
      "versionCode": 1,
      "permissions": ["android.permission.NFC"]
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "SPET uses NFC to scan guest wristbands for fast venue entry.",
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      },
      "privacyPolicyUrl": "https://spetapp.com/privacy",
      "supportUrl": "https://spetapp.com/support"
    }
  }
}
