{
  "expo": {
    "name": "SPET",
    "slug": "spet-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "spet",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5073c0c3-bea4-43e8-a6f0-c133b29b82ff",
      "fallbackToCacheTimeout": 5000
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spetapp.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NFCReaderUsageDescription": "SPET uses NFC to scan guest wristbands for fast venue entry.",
        "com.apple.developer.nfc.readersession.iso7816.select-identifiers": [],
        "com.apple.developer.nfc.readersession.felica.systemcodes": []
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.spetapp.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "plugins": [
      "expo-updates",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "SPET uses NFC to scan guest wristbands for fast venue entry.",
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ],
      "./plugins/withNfcEntitlementFix"
    ],
    "extra": {
      "privacyPolicyUrl": "https://spetapp.com/privacy",
      "supportUrl": "https://spetapp.com/support",
      "eas": {
        "projectId": "5073c0c3-bea4-43e8-a6f0-c133b29b82ff"
      }
    },
    "owner": "raphazitto"
  }
}
